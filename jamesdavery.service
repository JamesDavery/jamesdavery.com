[Unit]
Description=jamesdavery.com Next.js Application
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/jamesdavery
ExecStart=/usr/bin/node /var/www/jamesdavery/node_modules/.bin/next start -p 3000
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
